@page "/login"
@layout PublicLayout
@inject HttpClient Http
@inject NavigationManager Nav
@inject TokenStorageService TokenStorage

<PageTitle>Login - AdmissionPlex</PageTitle>

<section style="min-height:100vh; display:flex; align-items:center; justify-content:center; padding:120px 20px 80px;">
    <div class="card" style="width:100%; max-width:420px; padding:40px;">
        <div style="text-align:center; margin-bottom:32px;">
            <div class="nav-brand-icon" style="margin:0 auto 16px; width:48px; height:48px; font-size:20px;">A</div>
            <h2 style="font-family:var(--ap-font-display); font-size:24px;">Welcome Back</h2>
            <p style="color:var(--ap-text-muted); font-size:14px;">Login to your AdmissionPlex account</p>
        </div>

        @if (!string.IsNullOrEmpty(error))
        {
            <div style="background:rgba(239,68,68,0.1); color:var(--ap-red); padding:12px 16px; border-radius:8px; font-size:13px; margin-bottom:16px;">@error</div>
        }

        <div class="form-group">
            <label class="form-label">Email</label>
            <input class="form-input" type="email" placeholder="you@example.com" @bind="email" />
        </div>
        <div class="form-group">
            <label class="form-label">Password</label>
            <input class="form-input" type="password" placeholder="••••••••" @bind="password"
                   @onkeydown="HandleKeyDown" />
        </div>

        <button class="btn btn-primary" style="width:100%; justify-content:center; padding:14px; font-size:15px; margin-top:8px;"
                @onclick="HandleLogin" disabled="@loading">
            @(loading ? "Logging in..." : "Login")
        </button>

        <p style="text-align:center; margin-top:20px; font-size:14px; color:var(--ap-text-muted);">
            Don't have an account? <a href="/register" style="font-weight:600;">Register</a>
        </p>

        <div style="margin-top:16px; padding-top:16px; border-top:1px solid var(--ap-border); text-align:center;">
            <p style="font-size:12px; color:var(--ap-text-muted);">Demo: admin@admissionplex.com / Admin@123456</p>
        </div>
    </div>
</section>

@code {
    private string email = "", password = "", error = "";
    private bool loading = false;

    private void HandleKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter") _ = HandleLogin();
    }

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            error = "Please enter both email and password.";
            return;
        }

        error = "";
        loading = true;
        StateHasChanged();

        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/login", new { email, password });

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginApiResponse>();
                if (result?.Success == true && result.Data != null)
                {
                    // Store token and user info
                    await TokenStorage.SetTokenAsync(result.Data.Token);
                    await TokenStorage.SetUserInfoAsync(result.Data.Role, result.Data.FullName, result.Data.Email);

                    // Redirect based on role
                    var redirectUrl = result.Data.Role switch
                    {
                        "Admin" => "/admin",
                        "Counsellor" => "/counsellor",
                        "Coordinator" => "/coordinator",
                        _ => "/student"
                    };

                    Nav.NavigateTo(redirectUrl, forceLoad: true);
                }
                else
                {
                    error = "Login failed. Please try again.";
                }
            }
            else
            {
                var errorResult = await response.Content.ReadFromJsonAsync<ErrorApiResponse>();
                error = errorResult?.Errors?.FirstOrDefault() ?? errorResult?.Message ?? "Invalid email or password.";
            }
        }
        catch (HttpRequestException)
        {
            error = "Cannot connect to the server. Make sure the API is running.";
        }
        catch (Exception ex)
        {
            error = $"Error: {ex.Message}";
        }

        loading = false;
        StateHasChanged();
    }

    private class LoginApiResponse
    {
        public bool Success { get; set; }
        public string? Message { get; set; }
        public LoginData? Data { get; set; }
        public List<string>? Errors { get; set; }
    }

    private class LoginData
    {
        public string Token { get; set; } = "";
        public string Email { get; set; } = "";
        public string Role { get; set; } = "";
        public string FullName { get; set; } = "";
    }

    private class ErrorApiResponse
    {
        public bool Success { get; set; }
        public string? Message { get; set; }
        public List<string>? Errors { get; set; }
    }
}
