@page "/admin/careers"
@layout AdminLayout
@inject ApiClient Api

<PageTitle>Career Library - Admin</PageTitle>

<div class="topbar">
    <div><h2>Career Library</h2><p class="topbar-subtitle">Manage career information and suitability weights</p></div>
    <div class="topbar-actions"><button class="btn btn-primary">+ Add Career</button></div>
</div>

@if (careers == null)
{
    <div class="spinner"></div>
}
else
{
    <div class="grid-3">
        @foreach (var career in careers)
        {
            <div class="card" style="cursor:pointer;">
                <div style="width:40px; height:4px; border-radius:2px; background:var(--ap-sky); margin-bottom:16px;"></div>
                <div style="font-weight:700; font-size:15px; margin-bottom:8px;">@career.Title</div>
                <div style="display:flex; gap:8px; margin-bottom:12px;">
                    <span class="badge badge-primary">@career.StreamName</span>
                </div>
                <div style="font-size:12px; color:var(--ap-text-muted); display:flex; justify-content:space-between;">
                    <span>Growth: @career.GrowthOutlook</span>
                    <span class="badge badge-green" style="font-size:11px;">Published</span>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<CareerItem>? careers;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Api.GetFromJsonAsync<ApiResponse<List<CareerItem>>>("api/careers");
            careers = response?.Data ?? new();
        }
        catch { careers = new(); }
    }

    private class CareerItem
    {
        public string Title { get; set; } = "";
        public string StreamName { get; set; } = "";
        public string GrowthOutlook { get; set; } = "";
    }
}
