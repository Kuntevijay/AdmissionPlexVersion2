@page "/admin/cutoffs"
@layout AdminLayout

<PageTitle>Cutoff Data - Admin</PageTitle>

<div class="topbar">
    <div><h2>Cutoff Data Management</h2><p class="topbar-subtitle">Import, manage and update engineering cutoff data</p></div>
    <div class="topbar-actions">
        <button class="btn btn-outline">Import CSV</button>
        <button class="btn btn-primary">+ Add Cutoff Entry</button>
    </div>
</div>

<div class="card" style="padding:60px; text-align:center;">
    <div style="font-size:48px; margin-bottom:16px;">📊</div>
    <h3 style="font-size:18px; margin-bottom:8px;">Cutoff Management</h3>
    <p style="color:var(--ap-text-muted); font-size:14px;">Import cutoff data via CSV or add entries manually. Manage colleges, branches, and exam-wise cutoffs.</p>
</div>
