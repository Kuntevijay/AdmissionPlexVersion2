@page "/quiz"
@layout PublicLayout
@inject HttpClient Http

<PageTitle>Career Quiz - AdmissionPlex</PageTitle>

<section style="padding:120px 60px 80px;">
    <div style="max-width:720px; margin:0 auto;">

        @if (result != null)
        {
            <!-- Results -->
            <div class="section-header" style="margin-bottom:32px;">
                <div class="section-tag" style="color:var(--ap-green);">Your Result</div>
                <h2 class="section-title">You're suited for <span style="color:var(--ap-primary);">@result.DominantStream</span></h2>
                <p class="section-subtitle">Based on @result.TotalAnswered answers</p>
            </div>

            <div class="card" style="margin-bottom:24px;">
                <h3 style="font-size:18px; font-weight:700; margin-bottom:20px;">Stream breakdown</h3>
                @foreach (var kv in result.StreamPercent.OrderByDescending(k => k.Value))
                {
                    <div style="display:flex; align-items:center; gap:12px; margin-bottom:12px;">
                        <span style="width:100px; font-size:14px; font-weight:600;">@kv.Key</span>
                        <div style="flex:1; height:28px; background:var(--ap-border); border-radius:14px; overflow:hidden;">
                            <div style="height:100%; width:@kv.Value%; background:@StreamColor(kv.Key); border-radius:14px; transition:width 0.5s;"></div>
                        </div>
                        <span style="width:50px; text-align:right; font-weight:700; font-size:16px; color:var(--ap-primary);">@kv.Value%</span>
                    </div>
                }
            </div>

            <div class="card" style="margin-bottom:24px;">
                <h3 style="font-size:18px; font-weight:700; margin-bottom:16px;">Top careers in @result.DominantStream</h3>
                <div style="display:flex; flex-wrap:wrap; gap:8px; margin-bottom:16px;">
                    @foreach (var c in GetCareersForStream(result.DominantStream))
                    { <span class="badge badge-primary" style="padding:8px 16px; font-size:13px;">@c</span> }
                </div>
                <p style="font-size:14px; color:var(--ap-text-muted);">Want a detailed report? Take the full psychometric assessment.</p>
            </div>

            <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
                <a href="/student/tests" class="btn btn-primary">Full Psychometric Assessment →</a>
                <a href="/careers?stream=@result.DominantStream" class="btn btn-outline">Explore @result.DominantStream Careers</a>
                <button class="btn btn-outline" @onclick="Restart">Retake Quiz</button>
            </div>
        }
        else if (questions.Any())
        {
            var current = questions[currentIndex];
            <div class="section-header" style="margin-bottom:24px;">
                <div class="section-tag" style="color:var(--ap-gold);">Career Quiz</div>
                <h2 class="section-title">Discover your <span style="color:var(--ap-primary);">stream</span></h2>
            </div>

            <!-- Progress -->
            <div style="display:flex; align-items:center; gap:12px; margin-bottom:24px;">
                <span style="font-size:13px; color:var(--ap-text-muted);">@(currentIndex + 1) / @questions.Count</span>
                <div style="flex:1; height:6px; background:var(--ap-border); border-radius:3px; overflow:hidden;">
                    <div style="height:100%; width:@(((currentIndex + 1) * 100) / questions.Count)%; background:var(--ap-primary); border-radius:3px; transition:width 0.3s;"></div>
                </div>
            </div>

            <div class="card" style="padding:32px; margin-bottom:20px;">
                <div style="font-size:18px; font-weight:600; line-height:1.6; margin-bottom:24px;">@current.Text</div>
                <div style="display:flex; flex-direction:column; gap:10px;">
                    @foreach (var opt in current.Options)
                    {
                        var sel = answers.ContainsKey(current.Id) && answers[current.Id] == opt.Id;
                        <button style="display:flex; align-items:center; gap:12px; padding:14px 18px; border-radius:10px;
                            border:2px solid @(sel ? "var(--ap-primary)" : "var(--ap-border)");
                            background:@(sel ? "rgba(27,77,62,0.06)" : "var(--ap-surface)");
                            cursor:pointer; text-align:left; font-family:var(--ap-font-body); font-size:15px; width:100%;"
                            @onclick="() => answers[current.Id] = opt.Id">
                            <div style="width:24px; height:24px; border-radius:50%; border:2px solid @(sel ? "var(--ap-primary)" : "var(--ap-border)");
                                display:flex; align-items:center; justify-content:center; flex-shrink:0;
                                background:@(sel ? "var(--ap-primary)" : "transparent");">
                                @if (sel) { <div style="width:8px; height:8px; border-radius:50%; background:#fff;"></div> }
                            </div>
                            <span>@opt.Text</span>
                        </button>
                    }
                </div>
            </div>

            <div style="display:flex; justify-content:space-between;">
                <button class="btn btn-outline" @onclick="Prev" disabled="@(currentIndex == 0)">← Back</button>
                @if (currentIndex < questions.Count - 1)
                { <button class="btn btn-primary" @onclick="Next" disabled="@(!answers.ContainsKey(current.Id))">Next →</button> }
                else
                { <button class="btn btn-primary" @onclick="Submit" disabled="@(answers.Count < questions.Count)">Submit →</button> }
            </div>
        }
        else if (loading)
        {
            <div class="spinner"></div>
        }
        else
        {
            <div class="card" style="padding:60px; text-align:center;">
                <div style="font-size:48px; margin-bottom:16px;">🎯</div>
                <h3>No quiz questions available</h3>
                <p style="color:var(--ap-text-muted);">Admin needs to import quiz questions first.</p>
            </div>
        }
    </div>
</section>

@code {
    private List<QuizQ> questions = new();
    private Dictionary<long, long> answers = new();
    private int currentIndex = 0;
    private bool loading = true;
    private QuizResult? result;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiResp<List<QuizQ>>>("api/import/quiz-questions");
            questions = resp?.Data ?? new();
        }
        catch { }
        loading = false;
    }

    private void Next() { if (currentIndex < questions.Count - 1) currentIndex++; }
    private void Prev() { if (currentIndex > 0) currentIndex--; }

    private void Submit()
    {
        var counts = new Dictionary<string, int> { ["Science"] = 0, ["Commerce"] = 0, ["Arts"] = 0 };
        int total = 0;
        foreach (var q in questions)
        {
            if (!answers.TryGetValue(q.Id, out var selId)) continue;
            var opt = q.Options.FirstOrDefault(o => o.Id == selId);
            if (opt?.Stream != null && counts.ContainsKey(opt.Stream)) { counts[opt.Stream]++; total++; }
        }
        var dominant = counts.OrderByDescending(kv => kv.Value).First().Key;
        result = new QuizResult
        {
            DominantStream = dominant, TotalAnswered = total,
            StreamPercent = counts.ToDictionary(kv => kv.Key, kv => total == 0 ? 0 : (int)Math.Round(100.0 * kv.Value / total))
        };
    }

    private void Restart() { answers.Clear(); currentIndex = 0; result = null; }
    private string StreamColor(string s) => s switch { "Science" => "var(--ap-sky)", "Commerce" => "var(--ap-green)", "Arts" => "var(--ap-gold)", _ => "var(--ap-primary)" };

    private string[] GetCareersForStream(string s) => s switch
    {
        "Science" => new[] { "Software Engineering", "Medicine", "Data Science", "Architecture", "Biotechnology" },
        "Commerce" => new[] { "Chartered Accountancy", "MBA", "Banking & Finance", "Digital Marketing", "Economics" },
        "Arts" => new[] { "Law", "Journalism", "Fine Arts & Design", "Psychology", "Civil Services" },
        _ => Array.Empty<string>()
    };

    class ApiResp<T> { public bool Success { get; set; } public T? Data { get; set; } }
    class QuizQ { public long Id { get; set; } public string Text { get; set; } = ""; public List<QuizOpt> Options { get; set; } = new(); }
    class QuizOpt { public long Id { get; set; } public string Text { get; set; } = ""; public string? Stream { get; set; } }
    class QuizResult { public string DominantStream = ""; public int TotalAnswered; public Dictionary<string, int> StreamPercent = new(); }
}
