@page "/careers"
@layout PublicLayout
@inject HttpClient Http

<PageTitle>Career Library - AdmissionPlex</PageTitle>

<section style="padding:120px 60px 80px;">
    <div style="max-width:1200px; margin:0 auto;">
        <div class="section-header">
            <div class="section-tag" style="color:var(--ap-primary);">Explore</div>
            <h2 class="section-title">Career Library</h2>
            <p class="section-subtitle">Discover 200+ career paths across Science, Commerce & Arts</p>
        </div>

        @if (careers == null)
        {
            <div class="spinner"></div>
        }
        else
        {
            <div class="grid-3">
                @foreach (var career in careers)
                {
                    <a href="/careers/@career.Slug" style="text-decoration:none; color:inherit;">
                        <div class="card" style="cursor:pointer; transition:transform 0.2s;">
                            <div style="width:40px; height:4px; border-radius:2px; background:var(--ap-primary); margin-bottom:16px;"></div>
                            <div style="font-weight:700; font-size:16px; margin-bottom:8px;">@career.Title</div>
                            <div style="display:flex; gap:8px; margin-bottom:12px;">
                                <span class="badge badge-primary">@career.StreamName</span>
                                @if (!string.IsNullOrEmpty(career.GrowthOutlook))
                                {
                                    <span class="badge badge-green">@career.GrowthOutlook</span>
                                }
                            </div>
                            <p style="font-size:13px; color:var(--ap-text-muted); line-height:1.6;">@career.Summary</p>
                        </div>
                    </a>
                }
            </div>
        }
    </div>
</section>

@code {
    private List<CareerListItem>? careers;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse<List<CareerListItem>>>("api/careers");
            careers = response?.Data ?? new();
        }
        catch { careers = new(); }
    }

    private class CareerListItem
    {
        public string Title { get; set; } = "";
        public string Slug { get; set; } = "";
        public string StreamName { get; set; } = "";
        public string Summary { get; set; } = "";
        public string? GrowthOutlook { get; set; }
    }
}
