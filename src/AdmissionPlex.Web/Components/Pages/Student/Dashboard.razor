@page "/student"
@layout StudentLayout
@inject ApiClient Api

<PageTitle>My Dashboard - AdmissionPlex</PageTitle>

<div class="topbar"><h2>My Dashboard</h2></div>

<div class="welcome-banner">
    <h2>Welcome back!</h2>
    <p>Take the psychometric assessment to discover your ideal career path.</p>
</div>

<div class="grid-4" style="margin-bottom:28px;">
    <a href="/student/assessment" style="text-decoration:none; color:inherit;">
        <div class="card" style="text-align:center; cursor:pointer;">
            <div style="width:44px;height:44px;border-radius:12px;background:rgba(139,92,246,0.1);display:flex;align-items:center;justify-content:center;font-size:20px;margin:0 auto 12px;">🧠</div>
            <div style="font-weight:700; font-size:13px;">Psychometric Test</div>
            <div style="font-size:11px; color:var(--ap-text-muted);">9 sub-tests · Full report</div>
        </div>
    </a>
    <a href="/quiz" style="text-decoration:none; color:inherit;">
        <div class="card" style="text-align:center; cursor:pointer;">
            <div style="width:44px;height:44px;border-radius:12px;background:rgba(34,197,94,0.1);display:flex;align-items:center;justify-content:center;font-size:20px;margin:0 auto 12px;">🎯</div>
            <div style="font-weight:700; font-size:13px;">Career Quiz</div>
            <div style="font-size:11px; color:var(--ap-text-muted);">Quick stream finder</div>
        </div>
    </a>
    <a href="/student/chat" style="text-decoration:none; color:inherit;">
        <div class="card" style="text-align:center; cursor:pointer;">
            <div style="width:44px;height:44px;border-radius:12px;background:rgba(74,144,217,0.1);display:flex;align-items:center;justify-content:center;font-size:20px;margin:0 auto 12px;">💬</div>
            <div style="font-weight:700; font-size:13px;">Career Chat</div>
            <div style="font-size:11px; color:var(--ap-text-muted);">Ask AI about careers</div>
        </div>
    </a>
    <a href="/student/sessions" style="text-decoration:none; color:inherit;">
        <div class="card" style="text-align:center; cursor:pointer;">
            <div style="width:44px;height:44px;border-radius:12px;background:rgba(232,99,74,0.1);display:flex;align-items:center;justify-content:center;font-size:20px;margin:0 auto 12px;">📅</div>
            <div style="font-weight:700; font-size:13px;">Book Counsellor</div>
            <div style="font-size:11px; color:var(--ap-text-muted);">1-on-1 guidance</div>
        </div>
    </a>
</div>

<div class="grid-2">
    <!-- Assessment Progress -->
    <div class="card" style="padding:0; overflow:hidden;">
        <div class="card-header" style="padding:18px 24px;"><h3>Assessment Progress</h3></div>
        @if (assessmentData == null)
        {
            <div style="padding:40px; text-align:center; color:var(--ap-text-muted);">
                <p>Start the psychometric test to see your progress here.</p>
                <a href="/student/assessment" class="btn btn-primary btn-sm" style="margin-top:8px;">Start Assessment →</a>
            </div>
        }
        else
        {
            <div style="padding:20px 24px;">
                <div style="display:flex; justify-content:space-between; font-size:13px; margin-bottom:8px;">
                    <span style="color:var(--ap-text-muted);">Progress</span>
                    <strong>@assessmentData.CompletedCount / @assessmentData.TotalCount completed</strong>
                </div>
                <div style="height:8px; background:var(--ap-border); border-radius:4px; overflow:hidden; margin-bottom:16px;">
                    <div style="height:100%; width:@(assessmentData.TotalCount > 0 ? assessmentData.CompletedCount * 100 / assessmentData.TotalCount : 0)%; background:var(--ap-primary); border-radius:4px;"></div>
                </div>
                @if (assessmentData.AllCompleted)
                {
                    <a href="/student/assessment/report" class="btn btn-primary btn-sm" style="width:100%; justify-content:center;">View Report →</a>
                }
                else
                {
                    <a href="/student/assessment" class="btn btn-primary btn-sm" style="width:100%; justify-content:center;">Continue Assessment →</a>
                }
            </div>
        }
    </div>

    <!-- Referral Card -->
    <div class="card" style="padding:0; overflow:hidden;">
        <div class="card-header" style="padding:18px 24px;"><h3>My Referrals</h3></div>
        <div style="padding:24px;">
            <div style="background:var(--ap-gold-light); border-radius:12px; padding:20px; text-align:center; margin-bottom:16px;">
                <div style="font-size:11px; color:var(--ap-text-muted); text-transform:uppercase; letter-spacing:1px; margin-bottom:6px;">Your Referral Code</div>
                <div style="font-family:var(--ap-font-display); font-size:28px; letter-spacing:4px;">SHARE2026</div>
            </div>
            <a href="/student/referrals" class="btn btn-primary" style="width:100%; justify-content:center;">View Referrals</a>
        </div>
    </div>
</div>

@code {
    private AssessmentProgress? assessmentData;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var resp = await Api.GetFromJsonAsync<ApiResponse<AssessmentProgress>>("api/assessment/overview");
                assessmentData = resp?.Data;
            }
            catch { }
            StateHasChanged();
        }
    }

    class AssessmentProgress
    {
        public int CompletedCount { get; set; }
        public int TotalCount { get; set; }
        public bool AllCompleted { get; set; }
    }
}
