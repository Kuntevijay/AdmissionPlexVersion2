@page "/counsellor"
@layout AdminLayout
@inject ApiClient Api

<PageTitle>Counsellor Dashboard - AdmissionPlex</PageTitle>

<div class="topbar"><div><h2>Counsellor Dashboard</h2><p class="topbar-subtitle">Manage your sessions and students</p></div></div>

<div class="grid-4" style="margin-bottom:28px;">
    <div class="stat-card"><div class="stat-label">Today's Sessions</div><div class="stat-value">3</div></div>
    <div class="stat-card"><div class="stat-label">This Week</div><div class="stat-value">12</div></div>
    <div class="stat-card"><div class="stat-label">Total Students</div><div class="stat-value">89</div></div>
    <div class="stat-card"><div class="stat-label">Avg Rating</div><div class="stat-value">4.8</div><div class="stat-change positive">⭐</div></div>
</div>

<div class="grid-2">
    <div class="card" style="padding:0; overflow:hidden;">
        <div class="card-header" style="padding:18px 24px;"><h3>Upcoming Sessions</h3></div>
        @if (sessions == null)
        { <div class="spinner"></div> }
        else if (sessions.Any())
        {
            @foreach (var s in sessions)
            {
                <div style="padding:16px 24px; border-bottom:1px solid var(--ap-border); display:flex; justify-content:space-between; align-items:center;">
                    <div>
                        <div style="font-weight:600;">@s.StudentName</div>
                        <div style="font-size:12px; color:var(--ap-text-muted);">@s.ScheduledAt.ToString("dd MMM, hh:mm tt") · @s.SessionType</div>
                    </div>
                    <span class="badge @(s.Status == "Completed" ? "badge-green" : "badge-gold")">@s.Status</span>
                </div>
            }
        }
        else
        {
            <div style="padding:40px; text-align:center; color:var(--ap-text-muted);">No upcoming sessions.</div>
        }
    </div>

    <div class="card">
        <h3 style="font-size:16px; font-weight:700; margin-bottom:16px;">My Availability</h3>
        <p style="font-size:13px; color:var(--ap-text-muted); margin-bottom:16px;">Set your weekly availability for student bookings.</p>
        @foreach (var day in new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday" })
        {
            <div style="display:flex; align-items:center; gap:12px; margin-bottom:8px;">
                <span style="width:100px; font-size:13px; font-weight:600;">@day</span>
                <input class="form-input" type="time" style="width:auto;" value="10:00" />
                <span style="color:var(--ap-text-muted);">to</span>
                <input class="form-input" type="time" style="width:auto;" value="18:00" />
            </div>
        }
        <button class="btn btn-primary btn-sm" style="margin-top:12px;">Save Availability</button>
    </div>
</div>

@code {
    private List<SessionItem>? sessions;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Api.GetFromJsonAsync<ApiResponse<List<SessionItem>>>("api/counsellor-sessions/counsellor-sessions");
            sessions = response?.Data ?? new();
        }
        catch { sessions = new(); }
    }

    private class SessionItem
    {
        public string StudentName { get; set; } = "";
        public string SessionType { get; set; } = "";
        public string Status { get; set; } = "";
        public DateTime ScheduledAt { get; set; }
    }
}
