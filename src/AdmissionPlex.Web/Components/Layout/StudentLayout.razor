@inherits LayoutComponentBase

<div class="admin-layout">
    <aside class="sidebar" style="width:220px;">
        <div class="sidebar-brand">
            <div class="sidebar-brand-icon">A</div>
            <span>AdmissionPlex</span>
        </div>
        <div style="margin:0 16px 24px; padding:16px; background:rgba(255,255,255,0.05); border-radius:12px; text-align:center;">
            <div class="avatar" style="width:48px;height:48px;font-size:18px;margin:0 auto 8px;">PS</div>
            <div style="font-weight:700; font-size:14px; color:#fff;">Student</div>
            <div style="font-size:11px; color:rgba(255,255,255,0.5);">My Account</div>
        </div>
        <NavLink class="sidebar-item" href="/student" Match="NavLinkMatch.All"><span class="icon">◫</span> Overview</NavLink>
        <NavLink class="sidebar-item" href="/student/tests"><span class="icon">📝</span> My Tests</NavLink>
        <NavLink class="sidebar-item" href="/student/results"><span class="icon">📊</span> Results</NavLink>
        <NavLink class="sidebar-item" href="/student/careers"><span class="icon">🎯</span> Career Map</NavLink>
        <NavLink class="sidebar-item" href="/student/chat"><span class="icon">💬</span> Career Chat</NavLink>
        <NavLink class="sidebar-item" href="/student/sessions"><span class="icon">📅</span> Counsellor Sessions</NavLink>
        <NavLink class="sidebar-item" href="/student/referrals"><span class="icon">🔗</span> My Referrals</NavLink>
        <NavLink class="sidebar-item" href="/student/profile"><span class="icon">👤</span> Profile</NavLink>
    </aside>
    <div class="main-content" style="margin-left:220px;">
        @Body
    </div>
</div>
