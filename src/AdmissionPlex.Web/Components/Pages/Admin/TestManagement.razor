@page "/admin/tests"
@layout AdminLayout
@inject ApiClient Api

<PageTitle>Test Management - Admin</PageTitle>

<div class="topbar">
    <div><h2>Test Management</h2><p class="topbar-subtitle">Create, edit, and manage all tests</p></div>
    <div class="topbar-actions">
        <button class="btn btn-outline" @onclick="() => showCats = !showCats">📂 Categories</button>
        <a href="/admin/questions" class="btn btn-outline">📥 Questions</a>
        <button class="btn btn-outline" @onclick="OpenNewContinuity">+ Continuity Test</button>
        <button class="btn btn-primary" @onclick="OpenNew">+ New Test</button>
    </div>
</div>

@if (!string.IsNullOrEmpty(msg))
{
    <div style="background:rgba(34,197,94,0.1); color:var(--ap-green); padding:10px 16px; border-radius:8px; font-size:13px; margin-bottom:16px;">@msg</div>
}
@if (!string.IsNullOrEmpty(err))
{
    <div style="background:rgba(239,68,68,0.1); color:var(--ap-red); padding:10px 16px; border-radius:8px; font-size:13px; margin-bottom:16px;">@err</div>
}

@if (showCats)
{
    <div class="card" style="margin-bottom:24px;">
        <h3 style="font-size:16px; font-weight:700; margin-bottom:16px;">Interest & Aptitude Categories</h3>
        <div class="grid-2" style="gap:24px;">
            <div>
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
                    <h4 style="font-size:14px; font-weight:600; color:var(--ap-coral);">Interest (@interestCats.Count)</h4>
                    <button class="btn btn-sm btn-primary" @onclick='() => { catType = "interest"; showCatForm = true; catForm = new CatModel(); }'>+ Add</button>
                </div>
                @foreach (var c in interestCats)
                {
                    <div style="display:flex; justify-content:space-between; align-items:center; padding:8px 12px; background:var(--ap-bg); border-radius:6px; margin-bottom:4px; font-size:13px;">
                        <span><strong>@c.Code</strong> — @c.Name</span>
                        <span style="font-size:11px; color:var(--ap-text-muted);">Order: @c.DisplayOrder</span>
                    </div>
                }
            </div>
            <div>
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
                    <h4 style="font-size:14px; font-weight:600; color:var(--ap-sky);">Aptitude (@aptitudeCats.Count)</h4>
                    <button class="btn btn-sm btn-primary" @onclick='() => { catType = "aptitude"; showCatForm = true; catForm = new CatModel(); }'>+ Add</button>
                </div>
                @foreach (var c in aptitudeCats)
                {
                    <div style="display:flex; justify-content:space-between; align-items:center; padding:8px 12px; background:var(--ap-bg); border-radius:6px; margin-bottom:4px; font-size:13px;">
                        <span><strong>@c.Code</strong> — @c.Name</span>
                        <span style="font-size:11px; color:var(--ap-text-muted);">Order: @c.DisplayOrder</span>
                    </div>
                }
            </div>
        </div>

        @if (showCatForm)
        {
            <div style="margin-top:16px; padding:16px; border:1px dashed var(--ap-primary); border-radius:8px;">
                <h4 style="font-size:14px; margin-bottom:8px;">Add @catType category</h4>
                <div class="grid-4" style="gap:8px; margin-bottom:8px;">
                    <div class="form-group"><label class="form-label">Code</label><input class="form-input" @bind="catForm.Code" placeholder="XX" /></div>
                    <div class="form-group"><label class="form-label">Name</label><input class="form-input" @bind="catForm.Name" placeholder="Category Name" /></div>
                    <div class="form-group"><label class="form-label">Description</label><input class="form-input" @bind="catForm.Description" /></div>
                    <div class="form-group"><label class="form-label">Order</label><input class="form-input" type="number" @bind="catForm.DisplayOrder" /></div>
                </div>
                <div style="display:flex; gap:8px;">
                    <button class="btn btn-primary btn-sm" @onclick="SaveCategory">Save</button>
                    <button class="btn btn-outline btn-sm" @onclick="() => showCatForm = false">Cancel</button>
                </div>
            </div>
        }
    </div>
}

@if (showContinuityForm)
{
    <div class="card" style="margin-bottom:24px; border:2px solid var(--ap-lavender);">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
            <h3 style="font-size:16px; font-weight:700; margin:0;">Create continuity flow test</h3>
            <button style="background:none; border:none; cursor:pointer; font-size:18px; color:var(--ap-text-muted);" @onclick="() => showContinuityForm = false">✕</button>
        </div>

        <p style="font-size:13px; color:var(--ap-text-muted); margin-bottom:16px;">
            A continuity flow test is a group of sequential sub-tests (like the psychometric assessment). 
            Define the parent group first, then add sub-tests below. Students must complete each sub-test in order.
        </p>

        <!-- Parent group config -->
        <div style="padding:16px; background:var(--ap-bg); border-radius:8px; margin-bottom:16px;">
            <h4 style="font-size:14px; font-weight:600; margin-bottom:10px;">Step 1: Parent group</h4>
            <div class="grid-3" style="gap:12px;">
                <div class="form-group"><label class="form-label">Group code *</label><input class="form-input" @bind="cfParentCode" placeholder="e.g. aptitude_battery" /></div>
                <div class="form-group"><label class="form-label">Display title *</label><input class="form-input" @bind="cfParentTitle" placeholder="e.g. Aptitude Battery Test" /></div>
                <div class="form-group"><label class="form-label">Icon</label><input class="form-input" @bind="cfParentIcon" placeholder="🧠" /></div>
            </div>
            <div class="grid-2" style="gap:12px; margin-top:8px;">
                <div class="form-group"><label class="form-label">Description</label><input class="form-input" @bind="cfParentDesc" placeholder="Description for students..." /></div>
                <div class="form-group"><label class="form-label">Total price (0 = free)</label><input class="form-input" type="number" @bind="cfParentPrice" /></div>
            </div>
        </div>

        <!-- Sub-tests list -->
        <div style="margin-bottom:16px;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
                <h4 style="font-size:14px; font-weight:600;">Step 2: Sub-tests (@cfSubTests.Count added)</h4>
                <button class="btn btn-outline btn-sm" @onclick="AddSubTest">+ Add sub-test</button>
            </div>

            @for (int i = 0; i < cfSubTests.Count; i++)
            {
                var idx = i;
                var sub = cfSubTests[idx];
                <div style="background:var(--ap-bg); border-radius:8px; padding:12px; margin-bottom:8px; border-left:3px solid var(--ap-lavender);">
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
                        <span style="font-size:13px; font-weight:600;">Sub-test @(idx + 1)</span>
                        <button style="background:none; border:none; cursor:pointer; color:var(--ap-red); font-size:13px;" @onclick="() => cfSubTests.RemoveAt(idx)">Remove</button>
                    </div>
                    <div class="grid-4" style="gap:8px;">
                        <div class="form-group"><label class="form-label">Code</label><input class="form-input" @bind="sub.Code" placeholder="sub_test_1" /></div>
                        <div class="form-group"><label class="form-label">Title</label><input class="form-input" @bind="sub.Title" placeholder="Part 1 — Basics" /></div>
                        <div class="form-group">
                            <label class="form-label">Category</label>
                            <select class="form-select" @bind="sub.Category">
                                <option value="Interest">Interest</option>
                                <option value="Aptitude">Aptitude</option>
                                <option value="IQ">IQ</option>
                            </select>
                        </div>
                        <div class="form-group"><label class="form-label">Duration (min)</label><input class="form-input" type="number" @bind="sub.DurationMinutes" /></div>
                    </div>
                    <div class="grid-3" style="gap:8px; margin-top:4px;">
                        <div class="form-group"><label class="form-label">Icon</label><input class="form-input" @bind="sub.Icon" placeholder="📝" /></div>
                        <div class="form-group">
                            <label class="form-label">Test type</label>
                            <select class="form-select" @bind="sub.TestType">
                                <option value="InterestSurvey">Interest Survey</option>
                                <option value="AptitudeTest">Aptitude Test</option>
                                <option value="IQTest">IQ Test</option>
                            </select>
                        </div>
                        <div class="form-group"><label class="form-label">Description</label><input class="form-input" @bind="sub.Description" /></div>
                    </div>
                </div>
            }
        </div>

        <div style="display:flex; gap:8px;">
            <button class="btn btn-primary" @onclick="SaveContinuityTest" disabled="@saving">@(saving ? "Creating..." : "Create All Sub-tests")</button>
            <button class="btn btn-outline" @onclick="() => showContinuityForm = false">Cancel</button>
        </div>
    </div>
}

@if (showForm)
{
    <div class="card" style="margin-bottom:24px; border:2px solid var(--ap-primary);">
        <h3 style="font-size:16px; font-weight:700; margin-bottom:16px;">@(editId > 0 ? "Edit test" : "Create new test")</h3>
        <div class="grid-3" style="gap:12px; margin-bottom:12px;">
            <div class="form-group"><label class="form-label">Code *</label><input class="form-input" @bind="f.Code" placeholder="career_quiz" /></div>
            <div class="form-group"><label class="form-label">Title *</label><input class="form-input" @bind="f.Title" /></div>
            <div class="form-group"><label class="form-label">Icon</label><input class="form-input" @bind="f.Icon" placeholder="📝" /></div>
        </div>
        <div class="grid-3" style="gap:12px; margin-bottom:12px;">
            <div class="form-group">
                <label class="form-label">Test type</label>
                <select class="form-select" @bind="f.TestType">
                    <option value="StreamSelector">Stream Selector (Quiz)</option>
                    <option value="PsychometricFull">Psychometric Full</option>
                    <option value="InterestSurvey">Interest Survey</option>
                    <option value="AptitudeTest">Aptitude Test</option>
                    <option value="IQTest">IQ Test</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Category</label>
                <select class="form-select" @bind="f.Category">
                    <option value="">— None —</option>
                    <option value="Interest">Interest</option>
                    <option value="Aptitude">Aptitude</option>
                    <option value="IQ">IQ</option>
                </select>
            </div>
            <div class="form-group"><label class="form-label">Duration (min)</label><input class="form-input" type="number" @bind="f.DurationMinutes" /></div>
        </div>
        <div class="form-group" style="margin-bottom:12px;">
            <label class="form-label">Description</label>
            <textarea class="form-textarea" @bind="f.Description" rows="2"></textarea>
        </div>
        <div class="grid-3" style="gap:12px; margin-bottom:12px;">
            <div class="form-group"><label class="form-label">Price (0 = free)</label><input class="form-input" type="number" @bind="f.Price" /></div>
            <div class="form-group"><label class="form-label">Display order</label><input class="form-input" type="number" @bind="f.DisplayOrder" /></div>
            <div class="form-group"><label class="form-label">Parent test code</label><input class="form-input" @bind="f.ParentTestCode" placeholder="psychometric" /></div>
        </div>
        <div style="display:flex; gap:20px; flex-wrap:wrap; margin-bottom:16px; padding:14px 16px; background:var(--ap-bg); border-radius:8px;">
            <label style="display:flex; align-items:center; gap:6px; font-size:13px; cursor:pointer;"><input type="checkbox" @bind="f.IsActive" /> Active</label>
            <label style="display:flex; align-items:center; gap:6px; font-size:13px; cursor:pointer;"><input type="checkbox" @bind="f.IsPublic" /> Public</label>
            <label style="display:flex; align-items:center; gap:6px; font-size:13px; cursor:pointer;"><input type="checkbox" @bind="f.RequiresPayment" /> Requires payment</label>
            <label style="display:flex; align-items:center; gap:6px; font-size:13px; cursor:pointer;"><input type="checkbox" @bind="f.IsContinuityFlow" /> Continuity flow</label>
            <label style="display:flex; align-items:center; gap:6px; font-size:13px; cursor:pointer;"><input type="checkbox" @bind="f.IncludesCounsellorSession" /> Counsellor</label>
        </div>
        <div style="display:flex; gap:8px;">
            <button class="btn btn-primary" @onclick="SaveTest" disabled="@saving">@(saving ? "Saving..." : editId > 0 ? "Update" : "Create")</button>
            <button class="btn btn-outline" @onclick="() => showForm = false">Cancel</button>
        </div>
    </div>
}

<div class="grid-4" style="margin-bottom:20px;">
    <div class="stat-card"><div class="stat-label">Total</div><div class="stat-value">@(tests?.Count ?? 0)</div></div>
    <div class="stat-card"><div class="stat-label">Active</div><div class="stat-value" style="color:var(--ap-green);">@(tests?.Count(t => t.IsActive) ?? 0)</div></div>
    <div class="stat-card"><div class="stat-label">Free</div><div class="stat-value">@(tests?.Count(t => !t.RequiresPayment) ?? 0)</div></div>
    <div class="stat-card"><div class="stat-label">Paid</div><div class="stat-value" style="color:var(--ap-gold);">@(tests?.Count(t => t.RequiresPayment) ?? 0)</div></div>
</div>

@if (tests == null)
{
    <div class="spinner"></div>
}
else if (!tests.Any())
{
    <div class="card" style="padding:60px; text-align:center;">
        <div style="font-size:48px; margin-bottom:16px;">📊</div>
        <h3>No tests yet</h3>
        <p style="color:var(--ap-text-muted);">Click "+ New Test" to create one.</p>
    </div>
}
else
{
    var standalone = tests.Where(t => string.IsNullOrEmpty(t.ParentTestCode)).OrderBy(t => t.DisplayOrder).ToList();
    var grouped = tests.Where(t => !string.IsNullOrEmpty(t.ParentTestCode)).GroupBy(t => t.ParentTestCode).ToList();

    @foreach (var t in standalone)
    {
        <div class="card" style="margin-bottom:10px; border-left:4px solid @(t.IsActive ? "var(--ap-green)" : "var(--ap-border)"); border-radius:0 12px 12px 0; opacity:@(t.IsActive ? "1" : "0.6");">
            <div style="display:flex; justify-content:space-between; align-items:start; gap:16px;">
                <div style="flex:1;">
                    <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px; flex-wrap:wrap;">
                        <span style="font-size:20px;">@(t.Icon ?? "📝")</span>
                        <h3 style="font-size:15px; font-weight:700; margin:0;">@t.Title</h3>
                        @if (t.IsActive) { <span class="badge badge-green" style="font-size:10px;">Active</span> } else { <span class="badge badge-coral" style="font-size:10px;">Inactive</span> }
                        @if (t.IsPublic) { <span class="badge badge-sky" style="font-size:10px;">Public</span> }
                        @if (t.RequiresPayment) { <span class="badge badge-gold" style="font-size:10px;">Paid</span> } else { <span class="badge badge-green" style="font-size:10px;">Free</span> }
                    </div>
                    @if (!string.IsNullOrEmpty(t.Description)) { <p style="font-size:12px; color:var(--ap-text-muted); margin-bottom:6px;">@t.Description</p> }
                    <div style="display:flex; gap:16px; font-size:11px; color:var(--ap-text-muted);">
                        <span>Code: <strong>@t.Code</strong></span><span>@t.TotalQuestions q</span><span>@t.DurationMinutes min</span>
                    </div>
                </div>
                <div style="display:flex; gap:6px; flex-shrink:0;">
                    <a href="/admin/tests/@t.Id/questions" class="btn btn-outline btn-sm" style="font-size:11px; padding:4px 10px;">Questions</a>
                    <button class="btn btn-sm @(t.IsActive ? "btn-outline" : "btn-primary")" style="font-size:11px; padding:4px 10px;" @onclick="() => ToggleActive(t)">@(t.IsActive ? "Deactivate" : "Activate")</button>
                    <button class="btn btn-outline btn-sm" style="font-size:11px; padding:4px 10px;" @onclick="() => EditTest(t)">Edit</button>
                    <button class="btn btn-sm btn-danger" style="font-size:11px; padding:4px 10px;" @onclick="() => DeleteTest(t.Id)">Del</button>
                </div>
            </div>
        </div>
    }

    @foreach (var group in grouped)
    {
        var subs = group.OrderBy(t => t.DisplayOrder).ToList();
        <div class="card" style="margin-bottom:10px; border-left:4px solid var(--ap-lavender); border-radius:0 12px 12px 0;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
                <div style="display:flex; align-items:center; gap:8px;">
                    <span style="font-size:20px;">🧠</span>
                    <h3 style="font-size:15px; font-weight:700; margin:0;">Psychometric Assessment</h3>
                    <span class="badge badge-lavender" style="font-size:10px;">@subs.Count sub-tests · Sequential</span>
                    <span class="badge @(subs.All(t => t.IsActive) ? "badge-green" : "badge-coral")" style="font-size:10px;">@(subs.All(t => t.IsActive) ? "Active" : "Partial")</span>
                </div>
                <span style="font-size:11px; color:var(--ap-text-muted);">Parent: <strong>@group.Key</strong></span>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px;">
                @foreach (var t in subs)
                {
                    <div style="background:var(--ap-bg); border-radius:8px; padding:10px 12px; opacity:@(t.IsActive ? "1" : "0.5");">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:4px;">
                            <span style="font-size:16px;">@(t.Icon ?? "📝")</span>
                            <span class="badge @(t.Category == "Interest" ? "badge-coral" : t.Category == "IQ" ? "badge-lavender" : "badge-sky")" style="font-size:9px;">@t.Category</span>
                        </div>
                        <div style="font-weight:600; font-size:12px; margin-bottom:2px;">@t.Title</div>
                        <div style="font-size:10px; color:var(--ap-text-muted);">@t.TotalQuestions q · @t.DurationMinutes min</div>
                        <div style="display:flex; gap:4px; margin-top:6px;">
                            <a href="/admin/tests/@t.Id/questions" class="btn btn-outline btn-sm" style="font-size:9px; padding:2px 6px;">Q's</a>
                            <button class="btn btn-outline btn-sm" style="font-size:9px; padding:2px 6px;" @onclick="() => EditTest(t)">Edit</button>
                            <button class="btn btn-sm @(t.IsActive ? "btn-outline" : "btn-primary")" style="font-size:9px; padding:2px 6px;" @onclick="() => ToggleActive(t)">@(t.IsActive ? "Off" : "On")</button>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
}

@code {
    private List<TestItem>? tests;
    private List<CatItem> interestCats = new();
    private List<CatItem> aptitudeCats = new();
    private bool showForm = false;
    private bool saving = false;
    private bool showCats = false;
    private bool showCatForm = false;
    private bool showContinuityForm = false;
    private string catType = "interest";

    // Continuity test form state
    private string cfParentCode = "";
    private string cfParentTitle = "";
    private string cfParentIcon = "🧠";
    private string cfParentDesc = "";
    private decimal cfParentPrice = 0;
    private List<SubTestModel> cfSubTests = new();
    private long editId = 0;
    private string msg = "";
    private string err = "";
    private FormModel f = new();
    private CatModel catForm = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Load();
            StateHasChanged();
        }
    }

    private async Task Load()
    {
        try
        {
            var resp = await Api.GetFromJsonAsync<ApiResponse<List<TestItem>>>("api/tests");
            tests = resp?.Data ?? new();
            interestCats = (await Api.GetFromJsonAsync<ApiResponse<List<CatItem>>>("api/interest-categories"))?.Data ?? new();
            aptitudeCats = (await Api.GetFromJsonAsync<ApiResponse<List<CatItem>>>("api/aptitude-categories"))?.Data ?? new();
        }
        catch { tests = new(); }
    }

    private async Task SaveCategory()
    {
        msg = ""; err = "";
        try
        {
            var url = catType == "interest" ? "api/interest-categories" : "api/aptitude-categories";
            var resp = await Api.PostAsJsonAsync(url, catForm);
            if (resp.IsSuccessStatusCode)
            {
                msg = "Category added.";
                showCatForm = false;
                await Load();
            }
            else
            {
                var e = await resp.Content.ReadFromJsonAsync<ApiResponse<object>>();
                err = e?.Errors?.FirstOrDefault() ?? "Failed.";
            }
        }
        catch (Exception ex) { err = ex.Message; }
        StateHasChanged();
    }

    private void OpenNewContinuity()
    {
        showContinuityForm = true;
        showForm = false;
        cfParentCode = "";
        cfParentTitle = "";
        cfParentIcon = "🧠";
        cfParentDesc = "";
        cfParentPrice = 0;
        cfSubTests = new();
        AddSubTest();
        AddSubTest();
    }

    private void AddSubTest()
    {
        var order = cfSubTests.Count + 1;
        cfSubTests.Add(new SubTestModel
        {
            Code = $"{cfParentCode}_{order}",
            Title = $"Part {order}",
            Category = "Aptitude",
            TestType = "AptitudeTest",
            DurationMinutes = 10,
            Icon = "📝"
        });
    }

    private async Task SaveContinuityTest()
    {
        if (string.IsNullOrWhiteSpace(cfParentCode) || string.IsNullOrWhiteSpace(cfParentTitle) || cfSubTests.Count == 0)
        {
            err = "Parent code, title, and at least one sub-test are required.";
            return;
        }
        saving = true; msg = ""; err = "";
        StateHasChanged();

        int created = 0;
        try
        {
            for (int i = 0; i < cfSubTests.Count; i++)
            {
                var sub = cfSubTests[i];
                var dto = new FormModel
                {
                    Code = string.IsNullOrWhiteSpace(sub.Code) ? $"{cfParentCode}_{i + 1}" : sub.Code,
                    Title = sub.Title,
                    TestType = sub.TestType,
                    Category = sub.Category,
                    Description = sub.Description,
                    Icon = sub.Icon,
                    DisplayOrder = i + 1,
                    DurationMinutes = sub.DurationMinutes,
                    Price = 0,
                    IsActive = true,
                    IsPublic = false,
                    RequiresPayment = cfParentPrice > 0,
                    IsContinuityFlow = true,
                    ParentTestCode = cfParentCode,
                    IncludesCounsellorSession = false
                };

                var resp = await Api.PostAsJsonAsync("api/tests", dto);
                if (resp.IsSuccessStatusCode) created++;
                else
                {
                    var body = await resp.Content.ReadAsStringAsync();
                    err = $"Failed on sub-test {i + 1}: {body}";
                    break;
                }
            }

            if (string.IsNullOrEmpty(err))
            {
                msg = $"Created continuity test '{cfParentTitle}' with {created} sub-tests.";
                showContinuityForm = false;
                await Load();
            }
        }
        catch (Exception ex) { err = ex.Message; }
        saving = false;
        StateHasChanged();
    }

    private void OpenNew()
    {
        editId = 0;
        f = new FormModel { IsActive = true, TestType = "PsychometricFull", Icon = "📝" };
        showForm = true;
    }

    private void EditTest(TestItem t)
    {
        editId = t.Id;
        f = new FormModel
        {
            Code = t.Code,
            Title = t.Title,
            TestType = t.TestType,
            Category = t.Category,
            Description = t.Description,
            Icon = t.Icon,
            DisplayOrder = t.DisplayOrder,
            DurationMinutes = t.DurationMinutes,
            Price = t.Price,
            IsActive = t.IsActive,
            IsPublic = t.IsPublic,
            RequiresPayment = t.RequiresPayment,
            IsContinuityFlow = t.IsContinuityFlow,
            ParentTestCode = t.ParentTestCode,
            Instructions = t.Instructions,
            IncludesCounsellorSession = t.IncludesCounsellorSession
        };
        showForm = true;
    }

    private async Task SaveTest()
    {
        if (string.IsNullOrWhiteSpace(f.Code) || string.IsNullOrWhiteSpace(f.Title))
        {
            err = "Code and Title are required.";
            return;
        }
        saving = true; msg = ""; err = "";
        StateHasChanged();
        try
        {
            HttpResponseMessage resp;
            if (editId > 0)
                resp = await Api.PutAsJsonAsync($"api/tests/{editId}", f);
            else
                resp = await Api.PostAsJsonAsync("api/tests", f);

            if (resp.IsSuccessStatusCode)
            {
                msg = editId > 0 ? "Test updated." : "Test created.";
                showForm = false;
                await Load();
            }
            else
            {
                err = "Save failed.";
            }
        }
        catch (Exception ex) { err = ex.Message; }
        saving = false;
        StateHasChanged();
    }

    private async Task ToggleActive(TestItem t)
    {
        msg = ""; err = "";
        try
        {
            var dto = new FormModel
            {
                Code = t.Code, Title = t.Title, TestType = t.TestType, Category = t.Category,
                Description = t.Description, Icon = t.Icon, DisplayOrder = t.DisplayOrder,
                DurationMinutes = t.DurationMinutes, Price = t.Price,
                IsActive = !t.IsActive,
                IsPublic = t.IsPublic, RequiresPayment = t.RequiresPayment,
                IsContinuityFlow = t.IsContinuityFlow, ParentTestCode = t.ParentTestCode,
                Instructions = t.Instructions, IncludesCounsellorSession = t.IncludesCounsellorSession
            };
            var resp = await Api.PutAsJsonAsync($"api/tests/{t.Id}", dto);
            if (resp.IsSuccessStatusCode)
            {
                msg = t.IsActive ? "Deactivated." : "Activated.";
                await Load();
            }
            else { err = "Toggle failed."; }
        }
        catch (Exception ex) { err = ex.Message; }
        StateHasChanged();
    }

    private async Task DeleteTest(long id)
    {
        msg = ""; err = "";
        try
        {
            var resp = await Api.DeleteAsync($"api/tests/{id}");
            if (resp.IsSuccessStatusCode)
            {
                msg = "Deleted.";
                await Load();
            }
            else { err = "Delete failed."; }
        }
        catch (Exception ex) { err = ex.Message; }
        StateHasChanged();
    }

