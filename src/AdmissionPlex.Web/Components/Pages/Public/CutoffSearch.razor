@page "/cutoffs"
@layout PublicLayout
@inject HttpClient Http

<PageTitle>Engineering Cutoffs - AdmissionPlex</PageTitle>

<section style="padding:120px 60px 80px;">
    <div style="max-width:1200px; margin:0 auto;">
        <div class="section-header">
            <div class="section-tag" style="color:var(--ap-coral);">Engineering</div>
            <h2 class="section-title">Cutoff Analyzer & Predictor</h2>
        </div>

        <div class="card" style="overflow:hidden;">
            <!-- Filters -->
            <div style="padding:20px 28px; border-bottom:1px solid var(--ap-border); display:flex; gap:12px; align-items:center; flex-wrap:wrap;">
                <select class="form-select" style="width:auto;" @bind="selectedExam">
                    <option value="">All Exams</option>
                    <option value="MHT_CET">MHT-CET</option>
                    <option value="JEE_Main">JEE Main</option>
                    <option value="JEE_Advanced">JEE Advanced</option>
                </select>
                <input class="form-input" style="width:auto;" type="number" placeholder="Year" @bind="selectedYear" />
                <select class="form-select" style="width:auto;" @bind="selectedCategory">
                    <option value="">All Categories</option>
                    <option value="OPEN">OPEN</option>
                    <option value="OBC">OBC</option>
                    <option value="SC">SC</option>
                    <option value="ST">ST</option>
                    <option value="EWS">EWS</option>
                </select>
                <button class="btn btn-coral" style="margin-left:auto;" @onclick="SearchCutoffs">Search</button>
            </div>

            @if (loading)
            {
                <div class="spinner"></div>
            }
            else if (cutoffs != null && cutoffs.Any())
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>College</th>
                            <th>Branch</th>
                            <th>Category</th>
                            <th>Percentile</th>
                            <th>Year</th>
                            <th>Round</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in cutoffs)
                        {
                            <tr>
                                <td style="font-weight:600;">@c.CollegeName</td>
                                <td>@c.BranchName</td>
                                <td><span class="badge badge-primary">@c.Category</span></td>
                                <td style="font-weight:700; color:var(--ap-primary);">@c.CutoffPercentile</td>
                                <td>@c.Year</td>
                                <td>@c.Round</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div style="padding:60px; text-align:center; color:var(--ap-text-muted);">
                    <div style="font-size:48px; margin-bottom:16px;">🔍</div>
                    <p>Select filters and click Search to find cutoff data.</p>
                </div>
            }
        </div>
    </div>
</section>

@code {
    private string selectedExam = "";
    private int? selectedYear;
    private string selectedCategory = "";
    private bool loading = false;
    private List<CutoffResult>? cutoffs;

    private async Task SearchCutoffs()
    {
        loading = true;
        try
        {
            var query = $"api/cutoffs/search?exam={selectedExam}&category={selectedCategory}";
            if (selectedYear.HasValue) query += $"&year={selectedYear}";
            var response = await Http.GetFromJsonAsync<ApiResponse<List<CutoffResult>>>(query);
            cutoffs = response?.Data;
        }
        catch { cutoffs = new(); }
        loading = false;
    }

    private class CutoffResult
    {
        public string CollegeName { get; set; } = "";
        public string BranchName { get; set; } = "";
        public string Category { get; set; } = "";
        public decimal? CutoffPercentile { get; set; }
        public int Year { get; set; }
        public int Round { get; set; }
    }
}
