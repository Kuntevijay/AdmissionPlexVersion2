@inherits LayoutComponentBase
@inject TokenStorageService TokenStorage
@inject NavigationManager Nav

<div class="admin-layout">
    <aside class="sidebar">
        <div class="sidebar-brand">
            <img src="images/logo_.png" alt="AdmissionPlex" class="sidebar-brand-img" />
            <span>AdmissionPlex</span>
        </div>
        <div class="sidebar-section">Admin Panel</div>
        <NavLink class="sidebar-item" href="/admin" Match="NavLinkMatch.All"><span class="icon">◫</span> Dashboard</NavLink>
        <NavLink class="sidebar-item" href="/admin/questions"><span class="icon">❓</span> Question Bank</NavLink>
        <NavLink class="sidebar-item" href="/admin/tests"><span class="icon">📊</span> Tests</NavLink>
        <NavLink class="sidebar-item" href="/admin/careers"><span class="icon">🎯</span> Career Info</NavLink>
        <NavLink class="sidebar-item" href="/admin/cutoffs"><span class="icon">✂️</span> Cutoff Data</NavLink>
        <NavLink class="sidebar-item" href="/admin/users"><span class="icon">👥</span> Users</NavLink>
        <NavLink class="sidebar-item" href="/admin/coordinators"><span class="icon">🤝</span> Coordinators</NavLink>
        <NavLink class="sidebar-item" href="/admin/counsellors"><span class="icon">💬</span> Counsellors</NavLink>
        <NavLink class="sidebar-item" href="/admin/referrals"><span class="icon">🔗</span> Referrals</NavLink>
        <NavLink class="sidebar-item" href="/admin/pages"><span class="icon">📄</span> Pages / CMS</NavLink>
        <NavLink class="sidebar-item" href="/admin/settings"><span class="icon">⚙️</span> Settings</NavLink>

        <div style="margin-top:auto; padding:16px 20px; border-top:1px solid rgba(255,255,255,0.1); margin-top:24px;">
            <ThemeToggle InSidebar="true" />
            <button class="sidebar-item" style="width:100%; color:rgba(255,255,255,0.6);" @onclick="SignOut">
                <span class="icon">🚪</span> Sign Out
            </button>
        </div>
    </aside>
    <div class="main-content">
        @Body
    </div>
</div>

@code {
    private async Task SignOut()
    {
        await TokenStorage.ClearAllAsync();
        Nav.NavigateTo("/login", forceLoad: true);
    }
}
